        "abstentionSignalKind": {
          "anyOf": [
            {
              "enum": [
                "rank_null_candidate",
                "selector_head",
                "evidential_dirichlet",
                "rl_action_head",
                "gambler_class",
                "none"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Abstentionsignalkind"
        }
      },
      "title": "ModelEvidenceProvenance",
      "type": "object"
    },
    "OutcomeAdjustment": {
      "properties": {
        "reason": {
          "$ref": "#/$defs/AdjustmentReason"
        },
        "appliedCandidate": {
          "$ref": "#/$defs/CandidateRef"
        },
        "suppressedFrom": {
          "anyOf": [
            {
              "$ref": "#/$defs/CandidateRef"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "reason",
        "appliedCandidate"
      ],
      "title": "OutcomeAdjustment",
      "type": "object"
    },
    "PoolingMode": {
      "enum": [
        "mean",
        "logsumexp",
        "attention",
        "other"
      ],
      "title": "PoolingMode",
      "type": "string"
    },
    "RankBelief": {
      "properties": {
        "rankLevel": {
          "title": "Ranklevel",
          "type": "integer"
        },
        "rankName": {
          "title": "Rankname",
          "type": "string"
        },
        "candidates": {
          "items": {
            "discriminator": {
              "mapping": {
                "rank_null": "#/$defs/RankNullCandidate",
                "residual_below_taxon": "#/$defs/ResidualBelowTaxonCandidate",
                "taxon": "#/$defs/TaxonCandidate"
