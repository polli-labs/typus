      "required": [
        "rankLevel",
        "rankName",
        "candidates"
      ],
      "title": "RankBelief",
      "type": "object"
    },
    "RankNullCandidate": {
      "properties": {
        "rankLevel": {
          "title": "Ranklevel",
          "type": "integer"
        },
        "rankName": {
          "title": "Rankname",
          "type": "string"
        },
        "score": {
          "title": "Score",
          "type": "number"
        },
        "scoreSemantics": {
          "$ref": "#/$defs/ScoreSemantics"
        },
        "kind": {
          "const": "rank_null",
          "default": "rank_null",
          "title": "Kind",
          "type": "string"
        },
        "nullTaxonId": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
