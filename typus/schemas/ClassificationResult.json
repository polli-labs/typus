        "rank_softmax_probability",
        "temperature_scaled_rank_probability",
        "calibrated_rank_probability",
        "authored_assertion_weight",
        "synthetic_demo_weight",
        "conformal_set_membership",
        "display_weight"
      ],
      "title": "ScoreSemantics",
      "type": "string"
    },
    "TaxonCandidate": {
