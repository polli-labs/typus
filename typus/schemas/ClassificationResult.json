          "title": "Decisionpolicies",
          "type": "array"
        }
      },
      "required": [
        "sourceKind",
        "producer",
        "decisionPolicies"
      ],
      "title": "ClassificationProvenance",
      "type": "object"
    },
    "ClassificationSourceKind": {
      "enum": [
        "model_inference",
        "curated_taxon_card",
        "synthetic_demo",
        "cache_replay",
        "test_fixture"
      ],
      "title": "ClassificationSourceKind",
      "type": "string"
    },
    "DecisionOutcome": {
      "properties": {
        "rankLevel": {
          "title": "Ranklevel",
          "type": "integer"
        },
        "decision": {
          "enum": [
            "commit",
            "abstain"
          ],
          "title": "Decision",
          "type": "string"
        },
        "resolvedTo": {
          "anyOf": [
            {
              "$ref": "#/$defs/CandidateRef"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "decisionScore": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Decisionscore"
        },
        "decisionScoreSemantics": {
          "anyOf": [
            {
              "$ref": "#/$defs/DecisionScoreSemantics"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "derivedFromPolicyId": {
          "title": "Derivedfrompolicyid",
          "type": "string"
        },
        "adjustment": {
          "$ref": "#/$defs/OutcomeAdjustment"
        }
      },
      "required": [
        "rankLevel",
        "decision",
        "derivedFromPolicyId",
        "adjustment"
      ],
      "title": "DecisionOutcome",
      "type": "object"
    },
    "DecisionPolicy": {
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/DecisionPolicyKind"
