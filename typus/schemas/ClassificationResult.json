      },
      "required": [
        "granularity"
      ],
      "title": "InputAttribution",
      "type": "object"
    },
    "ModelEvidenceProvenance": {
      "properties": {
        "headKind": {
          "anyOf": [
            {
              "enum": [
                "conditional_classifier",
                "hierarchical_softmax",
                "other"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Headkind"
        },
        "routing": {
          "anyOf": [
            {
              "$ref": "#/$defs/RoutingProvenance"
            },
            {
              "type": "null"
            }
          ],
          "default": null
