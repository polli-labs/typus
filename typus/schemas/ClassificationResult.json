      "title": "ClassificationInputContext",
      "type": "object"
    },
    "ClassificationProvenance": {
      "properties": {
        "sourceKind": {
          "$ref": "#/$defs/ClassificationSourceKind"
        },
        "producer": {
          "title": "Producer",
          "type": "string"
        },
        "modelName": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Modelname"
        },
        "modelVersion": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Modelversion"
        },
        "checkpointUri": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Checkpointuri"
        },
        "checkpointSha": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Checkpointsha"
        },
        "inferenceTimestamp": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Inferencetimestamp"
        },
        "requestedTopK": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Requestedtopk"
        },
        "handlerVersion": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Handlerversion"
        },
        "modelEvidence": {
          "anyOf": [
            {
              "$ref": "#/$defs/ModelEvidenceProvenance"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "calibration": {
          "anyOf": [
            {
              "$ref": "#/$defs/CalibrationProvenance"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "decisionPolicies": {
          "items": {
            "$ref": "#/$defs/DecisionPolicy"
