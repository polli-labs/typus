      "title": "Schemaversion",
      "type": "string"
    },
    "taxonomyContext": {
      "$ref": "#/$defs/TaxonomyContext"
    },
    "provenance": {
      "$ref": "#/$defs/ClassificationProvenance"
    },
    "inputContext": {
      "$ref": "#/$defs/ClassificationInputContext"
    },
    "consistency": {
      "$ref": "#/$defs/ClassificationConsistency"
    },
