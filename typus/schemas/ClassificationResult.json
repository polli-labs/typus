        "parameters": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Parameters"
        },
        "chainOrder": {
          "title": "Chainorder",
          "type": "integer"
        }
      },
      "required": [
        "id",
        "kind",
        "chainOrder"
      ],
      "title": "DecisionPolicy",
      "type": "object"
