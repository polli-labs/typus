{
  "$defs": {
    "AdjustmentReason": {
      "enum": [
        "commit_top_candidate",
        "commit_thresholded",
        "commit_after_repair",
        "abstain_model_natural",
        "abstain_threshold_not_met",
        "abstain_parent_abstained",
        "abstain_hierarchy_conflict",
        "abstain_unmapped_taxon",
        "abstain_conformal_set_open",
        "curated_authored"
      ],
      "title": "AdjustmentReason",
      "type": "string"
    },
    "AggregationStage": {
      "enum": [
        "none",
        "pooled_before_heads",
        "aggregated_after_heads",
        "unknown"
      ],
      "title": "AggregationStage",
      "type": "string"
    },
    "AttributionGranularity": {
      "enum": [
        "none",
        "view",
        "frame",
        "patch",
        "segment",
        "tracklet"
      ],
      "title": "AttributionGranularity",
      "type": "string"
    },
    "AttributionSemantics": {
      "enum": [
        "attention_weight",
        "per_unit_logits",
        "gradient",
        "heuristic"
      ],
      "title": "AttributionSemantics",
      "type": "string"
    },
    "CalibrationMethod": {
      "enum": [
        "temperature_scaling",
        "isotonic",
        "platt",
        "conformal"
      ],
      "title": "CalibrationMethod",
      "type": "string"
    },
    "CalibrationProvenance": {
      "properties": {
        "method": {
          "$ref": "#/$defs/CalibrationMethod"
        },
        "calibrationSetId": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Calibrationsetid"
        },
        "parameters": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Parameters"
        },
        "targetCoverage": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Targetcoverage"
        }
      },
      "required": [
        "method"
      ],
      "title": "CalibrationProvenance",
      "type": "object"
    },
    "CandidateRef": {
      "properties": {
        "rankLevel": {
          "title": "Ranklevel",
          "type": "integer"
        },
        "match": {
          "discriminator": {
            "mapping": {
              "rank_null": "#/$defs/RankNullCandidateMatch",
              "residual_below_taxon": "#/$defs/ResidualBelowTaxonCandidateMatch",
              "taxon": "#/$defs/TaxonCandidateMatch"
            },
            "propertyName": "kind"
          },
          "oneOf": [
            {
              "$ref": "#/$defs/TaxonCandidateMatch"
            },
            {
              "$ref": "#/$defs/RankNullCandidateMatch"
            },
            {
              "$ref": "#/$defs/ResidualBelowTaxonCandidateMatch"
            }
          ],
          "title": "Match"
        }
      },
      "required": [
        "rankLevel",
        "match"
      ],
      "title": "CandidateRef",
      "type": "object"
    },
    "ClassificationConsistency": {
      "properties": {
        "hierarchyChecked": {
          "title": "Hierarchychecked",
          "type": "boolean"
        },
        "isConsistent": {
          "title": "Isconsistent",
          "type": "boolean"
        }
      },
      "required": [
        "hierarchyChecked",
        "isConsistent"
      ],
      "title": "ClassificationConsistency",
      "type": "object"
    },
    "ClassificationInputContext": {
      "properties": {
        "entityType": {
          "enum": [
            "image",
            "crop",
            "detection",
            "track",
            "observation",
            "card"
