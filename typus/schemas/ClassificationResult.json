          "default": "residual_below_taxon",
          "title": "Kind",
          "type": "string"
        },
        "parentTaxonId": {
          "title": "Parenttaxonid",
          "type": "integer"
        }
      },
      "required": [
        "parentTaxonId"
      ],
      "title": "ResidualBelowTaxonCandidateMatch",
      "type": "object"
    },
    "RoutingProvenance": {
