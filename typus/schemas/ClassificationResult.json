        },
        "score": {
          "title": "Score",
          "type": "number"
        },
        "scoreSemantics": {
          "$ref": "#/$defs/ScoreSemantics"
        },
        "kind": {
          "const": "residual_below_taxon",
          "default": "residual_below_taxon",
          "title": "Kind",
          "type": "string"
        },
        "parentTaxonId": {
          "title": "Parenttaxonid",
          "type": "integer"
        },
        "targetRankLevel": {
          "title": "Targetranklevel",
          "type": "integer"
