          "type": "string"
        },
        "evidenceShape": {
          "$ref": "#/$defs/EvidenceShape"
        },
        "unitCount": {
          "title": "Unitcount",
          "type": "integer"
        },
        "unitIds": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Unitids"
        },
        "aggregation": {
          "anyOf": [
            {
              "$ref": "#/$defs/InputAggregation"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "attribution": {
          "anyOf": [
            {
              "$ref": "#/$defs/InputAttribution"
            },
            {
              "type": "null"
            }
          ],
          "default": null
